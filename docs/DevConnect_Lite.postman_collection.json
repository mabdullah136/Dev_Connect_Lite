    {
      "name": "Connections",
      "item": [
        {
          "name": "Send Connection Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/connections/request/{{targetUserId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "connections", "request", "{{targetUserId}}"]
            },
            "description": "Send a connection request to target user. Set targetUserId variable first."
          },
          "response": []
        },
        {
          "name": "Accept Connection Request",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/connections/accept/{{fromUserId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "connections", "accept", "{{fromUserId}}"]
            },
            "description": "Accept a pending request from fromUserId."
          },
          "response": []
        },
        {
          "name": "Reject Connection Request",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/connections/reject/{{fromUserId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "connections", "reject", "{{fromUserId}}"]
            },
            "description": "Reject a pending request from fromUserId."
          },
          "response": []
        },
        {
          "name": "Get Incoming Requests",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/connections/incoming",
              "host": ["{{baseUrl}}"],
              "path": ["api", "connections", "incoming"]
            },
            "description": "List incoming pending requests for the authenticated user."
          },
          "response": []
        },
        {
          "name": "Get My Connections",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/connections",
              "host": ["{{baseUrl}}"],
              "path": ["api", "connections"]
            },
            "description": "List accepted connections for the authenticated user."
          },
          "response": []
        }
      ]
    }
